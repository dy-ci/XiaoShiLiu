# 服务器配置
PORT=3001
NODE_ENV=development

# JWT配置
# JWT_SECRET 必须设置固定值，否则每次重启会导致所有Token失效
# 示例: JWT_SECRET=xiaoshiliu_secret_key_2025_production
JWT_SECRET=
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# 数据库配置
# 数据库类型: sqlite3 (本地开发) 或 pg (生产环境 PostgreSQL)
# 默认使用 pg (PostgreSQL)
DB_TYPE=pg

# === SQLite 配置（本地开发可选）===
SQLITE_DB_PATH=./data/dev.sqlite3

# === PostgreSQL 配置（生产环境和开发环境默认使用）===
# 支持 PG_HOST 或 DB_HOST 等别名
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_secure_password_here
PG_DATABASE=xiaoshiliu

# === Redis 配置（缓存、会话、限流）===
# Redis 连接URL（默认本地Redis）
REDIS_URL=redis://localhost:6379
# Redis 密码（无密码时留空）
REDIS_PASSWORD=
# Redis 端口（Docker映射时使用）
REDIS_PORT=6379

# API配置
API_BASE_URL=http://localhost:3001

# 上传配置
# 单张图片最大文件大小
IMAGE_MAX_SIZE=10mb
# 单个视频最大文件大小
VIDEO_MAX_SIZE=100mb
# 图片上传策略 (local: 本地存储, imagehost: 第三方图床, r2: Cloudflare R2)
IMAGE_UPLOAD_STRATEGY=imagehost
# 视频上传策略 (local: 本地存储, r2: Cloudflare R2)
VIDEO_UPLOAD_STRATEGY=local

# 本地存储配置
LOCAL_UPLOAD_DIR=uploads
LOCAL_BASE_URL=http://localhost:3001
# 图片本地存储目录
IMAGE_LOCAL_UPLOAD_DIR=uploads/images
# 视频本地存储目录
VIDEO_LOCAL_UPLOAD_DIR=uploads/videos

# 第三方图床配置（当IMAGE_UPLOAD_STRATEGY=imagehost时使用）
IMAGEHOST_API_URL=https://api.xinyew.cn/api/360tc
IMAGEHOST_TIMEOUT=60000

# Cloudflare R2 配置（当IMAGE_UPLOAD_STRATEGY=r2或VIDEO_UPLOAD_STRATEGY=r2时使用）
# 请从 Cloudflare 控制台获取您自己的配置信息
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your_bucket_name_here
R2_ACCOUNT_ID=your_account_id_here
R2_REGION=auto
# 可选：如果有自定义域名，可以设置 R2_PUBLIC_URL
# R2_PUBLIC_URL=https://your-custom-domain.com

# 注意：
# 1. R2_ACCOUNT_ID 需要从 Cloudflare 控制台获取
# 2. R2_BUCKET_NAME 需要先在 Cloudflare R2 中创建存储桶
# 3. 如果使用自定义域名，需要在 Cloudflare 中配置域名绑定
# 4. 请不要将真实的密钥提交到版本控制系统中

# CORS配置
# 多个origin用逗号分隔，例如: http://localhost:5173,http://localhost:3001
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# 邮件服务配置
# 是否启用邮件功能 (true/false)
# 默认不启用，设置为true时注册需要邮箱验证
EMAIL_ENABLED=false
# SMTP服务器地址
SMTP_HOST=smtp.qq.com
# SMTP服务器端口
SMTP_PORT=465
# 是否使用SSL/TLS (true/false)
SMTP_SECURE=true
# 邮箱账号
SMTP_USER=your_email@example.com
# 邮箱密码/授权码
SMTP_PASSWORD=your_email_password
# 发件人邮箱
EMAIL_FROM=your_email@example.com
# 发件人名称
EMAIL_FROM_NAME=悦社动态社区

# IP属地查询配置
# 主API地址
IP_LOCATION_PRIMARY_API=https://api.pearktrue.cn/api/ip/details
# 主API超时时间（毫秒）
IP_LOCATION_PRIMARY_TIMEOUT=10000
# 备用API地址
IP_LOCATION_BACKUP_API=https://api.pearktrue.cn/api/ip/high
# 备用API超时时间（毫秒）
IP_LOCATION_BACKUP_TIMEOUT=5000

# Logto 统一认证配置
# Logto 服务地址 (例如: https://your-logto-instance.com)
LOGTO_ENDPOINT=
# Logto 应用 ID
LOGTO_APP_ID=
# Logto 应用密钥
LOGTO_APP_SECRET=
# Logto 回调地址 (前端地址, 例如: http://localhost:5173/callback)
LOGTO_REDIRECT_URI=http://localhost:5173/callback
# Logto 管理员回调地址 (前端管理后台地址)
LOGTO_ADMIN_REDIRECT_URI=http://localhost:5173/admin/callback
# Logto 登出后跳转地址
LOGTO_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
# Logto Cookie 密钥 (可选，系统会自动生成)
LOGTO_COOKIE_SECRET=

# ==================== 生产环境配置示例 ====================
# 请根据实际服务器地址修改以下配置：
# 
# PORT=3001
# NODE_ENV=production
# 
# API_BASE_URL=https://api.yoursite.com
# CORS_ORIGIN=https://yoursite.com
# 
# LOGTO_ENDPOINT=https://logto.yoursite.com
# LOGTO_REDIRECT_URI=https://yoursite.com/callback
# LOGTO_ADMIN_REDIRECT_URI=https://yoursite.com/admin/callback
# LOGTO_POST_LOGOUT_REDIRECT_URI=https://yoursite.com
