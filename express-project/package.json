{
    "name": "express-project",
    "version": "1.0.0",
    "description": "悦社动态社区Express后端项目，基于原项目小石榴校园图文社区",
    "author": "@ZTMYO",
    "main": "app.js",
    "scripts": {
        "start": "node app.js",
        "dev": "nodemon app.js",
        "generate-data": "node scripts/generate-data.js",
        "init-db": "node scripts/init-database.js",
        "migrate:latest": "knex migrate:latest --knexfile knexfile.js",
        "migrate:rollback": "knex migrate:rollback --knexfile knexfile.js",
        "migrate:make": "knex migrate:make $npm_config_name --knexfile knexfile.js",
        "seed:run": "knex seed:run --knexfile knexfile.js",
        "seed:make": "knex seed:make $npm_config_name --knexfile knexfile.js"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.888.0",
        "@logto/node": "^2.3.0",
        "axios": "^1.11.0",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^17.2.2",
        "express": "^4.18.2",
        "express-rate-limit": "^6.11.2",
        "iconv-lite": "^0.7.2",
        "jsonwebtoken": "^9.0.2",
        "knex": "^3.2.10",
        "multer": "^2.0.2",
        "mysql2": "^3.6.0",
        "nodemailer": "^7.0.11",
        "pg": "^8.21.0",
        "redis": "^4.6.0",
        "sharp": "^0.33.0",
        "svg-captcha": "^1.4.0"
    },
    "devDependencies": {
        "nodemon": "^3.0.1"
    }
}
